#!/bin/bash
# sqlopt - SQL Optimizer CLI wrapper (Unix/Linux/macOS)
#
# Edit the paths below before running:
#   SQLOPT_HOME - path to sql-optimizer-skill
#   WORKDIR     - path to your business project (where sqlopt.yml is)

# ==== 配置区域 ====
SQLOPT_HOME="/path/to/sql-optimizer-skill"   # 请替换为实际路径
WORKDIR="/path/to/your/mybatis-project"    # 请替换为实际路径
# ==== 配置区域 ====

if [ ! -d "$SQLOPT_HOME" ]; then
    echo "Error: SQLOPT_HOME directory not found: $SQLOPT_HOME" >&2
    echo "Please edit this script and set the correct path" >&2
    exit 1
fi

if [ ! -d "$WORKDIR" ]; then
    echo "Error: WORKDIR directory not found: $WORKDIR" >&2
    echo "Please edit this script and set the correct path" >&2
    exit 1
fi

cd "$WORKDIR"
export PYTHONPATH="$SQLOPT_HOME/python"
exec python -m sqlopt.cli.main "$@"
