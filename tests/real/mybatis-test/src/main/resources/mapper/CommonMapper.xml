<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.mapper.CommonMapper">
    
    <!-- 通用列片段 -->
    <sql id="auditColumns">created_at</sql>
    
    <!-- 用户基础列 -->
    <sql id="userBaseColumns">id, name, email, status</sql>
    
    <!-- 订单基础列 -->
    <sql id="orderBaseColumns">id, user_id, status, total_amount</sql>
    
    <!-- 通用状态条件 -->
    <sql id="activeStatusCondition">
        <if test="status != null">AND status = #{status}</if>
    </sql>
    
    <!-- 通用分页条件 -->
    <sql id="paginationCondition">
        <if test="pageSize != null">LIMIT #{pageSize}</if>
        <if test="offset != null">OFFSET #{offset}</if>
    </sql>
    
    <!-- 通用时间范围条件 -->
    <sql id="dateRangeCondition">
        <if test="startDate != null">AND created_at >= #{startDate}</if>
        <if test="endDate != null">AND created_at &lt;= #{endDate}</if>
    </sql>
    
    <!-- 带嵌套 if 的复杂片段 -->
    <sql id="complexCommonCondition">
        <choose>
            <when test="status == 1">
                AND status = 1
            </when>
            <when test="status == 0">
                AND status = 0
            </when>
            <otherwise>
                AND status IN (0, 1)
            </otherwise>
        </choose>
    </sql>
</mapper>
