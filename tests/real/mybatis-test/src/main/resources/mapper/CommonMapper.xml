<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.mapper.CommonMapper">
    
    <!-- 通用列片段 -->
    <sql id="auditColumns">created_at, updated_at</sql>
    
    <!-- 用户基础列 -->
    <sql id="userBaseColumns">id, name, email, status, type</sql>
    
    <!-- 订单基础列 -->
    <sql id="orderBaseColumns">id, order_no, user_id, status, amount</sql>
    
    <!-- 通用状态条件 -->
    <sql id="activeStatusCondition">
        <if test="status != null">AND status = #{status}</if>
    </sql>
    
    <!-- 通用分页条件 -->
    <sql id="paginationCondition">
        <if test="pageSize != null">LIMIT #{pageSize}</if>
        <if test="offset != null">OFFSET #{offset}</if>
    </sql>
    
    <!-- 通用时间范围条件 -->
    <sql id="dateRangeCondition">
        <if test="startDate != null">AND created_at >= #{startDate}</if>
        <if test="endDate != null">AND created_at &lt;= #{endDate}</if>
    </sql>
    
    <!-- 带嵌套 if 的复杂片段 -->
    <sql id="complexCommonCondition">
        <choose>
            <when test="status == 'active'">
                AND status = '1'
                <if test="type != null">AND type = #{type}</if>
            </when>
            <when test="status == 'inactive'">
                AND status = '0'
            </when>
            <otherwise>
                AND status IN ('0', '1')
            </otherwise>
        </choose>
    </sql>
</mapper>
