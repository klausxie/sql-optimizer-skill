<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="demo.scan">
  <sql id="ActiveOnly">
    AND status = 'ACTIVE'
  </sql>

  <sql id="TenantGuard">
    <if test="tenantId != null">
      AND tenant_id = #{tenantId}
    </if>
  </sql>

  <select id="searchUsersAdvanced" resultType="map">
    SELECT id, name, email, status
    FROM users
    <bind name="likeName" value="'%' + name + '%'" />
    <where>
      <choose>
        <when test="name != null and name != ''">
          name ILIKE #{likeName}
        </when>
        <otherwise>
          1 = 1
          <include refid="ActiveOnly" />
        </otherwise>
      </choose>
      <include refid="TenantGuard" />
      <if test="ids != null and ids.size() > 0">
        AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
          #{id}
        </foreach>
      </if>
    </where>
  </select>

  <update id="patchUserStatusAdvanced" parameterType="map">
    UPDATE users
    <trim prefix="SET" suffixOverrides=",">
      <set>
        <if test="email != null">
          email = #{email},
        </if>
        <if test="status != null">
          status = #{status},
        </if>
      </set>
    </trim>
    WHERE id = #{id}
  </update>
</mapper>
