<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="demo.user">
  <sql id="UserBaseColumns">
    id, name, email, status, created_at, updated_at
  </sql>

  <resultMap id="userMap" type="com.example.model.User">
    <result jdbcType="VARCHAR" column="name" property="name" />
  </resultMap>

  <resultMap id="fullUserMap" type="com.example.model.User" extends="userMap">
    <result jdbcType="VARCHAR" column="email" property="email" />
  </resultMap>

  <select id="listUsers" resultMap="fullUserMap">
    SELECT <include refid="UserBaseColumns" />
    FROM users
  </select>

  <select id="findUsers" resultType="com.example.model.User">
    SELECT <include refid="UserBaseColumns" />
    FROM users
    <where>
      <if test="name != null and name != ''">
        AND name ILIKE CONCAT('%', #{name}, '%')
      </if>
      <if test="status != null and status != ''">
        AND status = #{status}
      </if>
    </where>
    ORDER BY ${orderBy}
  </select>

  <select id="listUsersSorted" resultType="map">
    SELECT *
    FROM users
    ORDER BY created_at DESC
  </select>

  <select id="findUsersByStatusRecent" resultType="map">
    SELECT id, name, email, status, created_at
    FROM users
    WHERE status = #{status}
    ORDER BY created_at DESC
  </select>

  <!-- SENSITIVE_COLUMN_EXPOSED: 敏感字段暴露 -->
  <select id="getUserWithPassword" resultType="map">
    SELECT id, name, password, token, credit_card FROM users
  </select>

  <!-- FULL_SCAN_RISK: 无 WHERE 全表扫描 -->
  <select id="getAllUserNames" resultType="map">
    SELECT name FROM users
  </select>

  <!-- SUBQUERY_IN_FROM: FROM 子句子查询 -->
  <select id="getActiveUserCounts" resultType="map">
    SELECT COUNT(*) FROM (SELECT id FROM users WHERE status = 'active') AS active_users
  </select>

  <!-- OR_CONDITION_NO_INDEX: OR 条件 -->
  <select id="findUsersByStatusOrRole" resultType="map">
    SELECT * FROM users WHERE status = 'pending' OR role = 'admin'
  </select>

  <!-- FUNCTION_ON_INDEXED_COL: 函数导致索引失效 -->
  <select id="findUsersByUpperName" resultType="map">
    SELECT * FROM users WHERE UPPER(name) = 'JOHN'
  </select>

  <!-- LIKE_WILDCARD_START: LIKE % 开头 -->
  <select id="searchUsersByNamePattern" resultType="map">
    SELECT * FROM users WHERE name LIKE '%john%'
  </select>

  <!-- JOIN_WITHOUT_ON: JOIN 无 ON -->
  <select id="getUserOrderWithoutJoin" resultType="map">
    SELECT u.name, o.order_id FROM users u JOIN orders o
  </select>

  <!-- DISTINCT_ABUSE: DISTINCT 滥用 -->
  <select id="getDistinctUsers" resultType="map">
    SELECT DISTINCT a, b, c, d, e, f, g FROM users
  </select>

  <!-- ORDER_BY_RANDOM: ORDER BY RAND() -->
  <select id="getRandomUser" resultType="map">
    SELECT * FROM users ORDER BY RAND()
  </select>
</mapper>
