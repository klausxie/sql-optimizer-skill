{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunReport",
  "type": "object",
  "required": [
    "run_id",
    "generated_at",
    "status",
    "verdict",
    "next_action",
    "phase_status"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "generated_at": {"type": "string"},
    "status": {"type": "string"},
    "verdict": {"type": "string"},
    "next_action": {"type": "string"},
    "phase_status": {
      "type": "object",
      "additionalProperties": {"type": ["string", "null"]}
    }
  }
}
