{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy",
  "type": "object",
  "required": [
    "require_perf_improvement",
    "cost_threshold_pct",
    "allow_seq_scan_if_rows_below",
    "semantic_strict_mode"
  ],
  "properties": {
    "require_perf_improvement": {"type": "boolean"},
    "cost_threshold_pct": {"type": "number", "minimum": 0},
    "allow_seq_scan_if_rows_below": {"type": "integer", "minimum": 0},
    "semantic_strict_mode": {"type": "boolean"}
  }
}
