{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationSummary",
  "type": "object",
  "required": [
    "run_id",
    "total_sql",
    "records_by_phase",
    "verified_count",
    "partial_count",
    "unverified_count",
    "coverage_by_phase",
    "top_reason_codes",
    "blocking_sql_keys",
    "generated_at"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "total_sql": {"type": "integer"},
    "records_by_phase": {"type": "object"},
    "verified_count": {"type": "integer"},
    "partial_count": {"type": "integer"},
    "unverified_count": {"type": "integer"},
    "coverage_by_phase": {"type": "object"},
    "top_reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason_code", "count"],
        "properties": {
          "reason_code": {"type": "string"},
          "count": {"type": "integer"}
        }
      }
    },
    "blocking_sql_keys": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string"}
  }
}
