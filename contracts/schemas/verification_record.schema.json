{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationRecord",
  "type": "object",
  "required": [
    "run_id",
    "sql_key",
    "statement_key",
    "phase",
    "status",
    "reason_code",
    "reason_message",
    "evidence_refs",
    "inputs",
    "checks",
    "verdict",
    "created_at"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "sql_key": {"type": "string"},
    "statement_key": {"type": "string"},
    "phase": {"type": "string"},
    "status": {"type": "string"},
    "reason_code": {"type": "string"},
    "reason_message": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "inputs": {"type": "object"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ok", "severity"],
        "properties": {
          "name": {"type": "string"},
          "ok": {"type": "boolean"},
          "severity": {"type": "string"},
          "reason_code": {"type": ["string", "null"]},
          "detail": {"type": ["string", "null"]},
          "evidence_ref": {"type": ["string", "null"]}
        }
      }
    },
    "verdict": {"type": "object"},
    "created_at": {"type": "string"}
  }
}
