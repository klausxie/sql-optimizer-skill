{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunIndex",
  "type": "object",
  "required": ["schema_version", "run_id", "layout_version", "authoritative", "read_order", "groups", "integrity"],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "generated_at": {"type": ["string", "null"]},
    "layout_version": {"type": "string"},
    "authoritative": {
      "type": "object",
      "required": ["runtime_state", "events", "consumer_summary"],
      "properties": {
        "runtime_state": {"type": "string"},
        "events": {"type": "string"},
        "consumer_summary": {"type": "array", "items": {"type": "string"}}
      }
    },
    "read_order": {
      "type": "object",
      "required": ["human", "machine"],
      "properties": {
        "human": {"type": "array", "items": {"type": "string"}},
        "machine": {"type": "array", "items": {"type": "string"}}
      }
    },
    "groups": {
      "type": "object",
      "required": ["overview", "pipeline", "sql", "diagnostics"],
      "properties": {
        "overview": {"type": "array", "items": {"type": "string"}},
        "pipeline": {"type": "array", "items": {"type": "string"}},
        "sql": {
          "type": "object",
          "required": ["catalog", "sql_keys"],
          "properties": {
            "catalog": {"type": "string"},
            "sql_keys": {"type": "array", "items": {"type": "string"}}
          }
        },
        "diagnostics": {"type": "array", "items": {"type": "string"}}
      }
    },
    "integrity": {
      "type": "object",
      "properties": {
        "status": {"type": ["string", "null"]},
        "warning_codes": {"type": ["array", "null"], "items": {"type": "string"}},
        "sql_key_alignment_ok": {"type": ["boolean", "null"]},
        "sql_artifact_count": {"type": ["integer", "null"]},
        "sql_ref_null_counts": {"type": ["object", "null"]},
        "sql_ref_issue_counts": {"type": ["object", "null"]},
        "sql_ref_issues": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "properties": {
              "sql_key": {"type": ["string", "null"]},
              "issues": {"type": ["array", "null"], "items": {"type": "string"}},
              "missing_refs": {"type": ["array", "null"], "items": {"type": "string"}}
            }
          }
        },
        "phase_status": {"type": ["object", "null"]}
      }
    }
  }
}
