{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SqlUnit",
  "type": "object",
  "required": [
    "sqlKey",
    "statementKey",
    "xmlPath",
    "namespace",
    "statementId",
    "statementType",
    "sql",
    "parameterMappings",
    "paramExample",
    "locators",
    "riskFlags"
  ],
  "properties": {
    "sqlKey": {"type": "string"},
    "statementKey": {"type": "string"},
    "xmlPath": {"type": "string"},
    "namespace": {"type": "string"},
    "statementId": {"type": "string"},
    "statementType": {"type": "string"},
    "variantId": {"type": ["string", "null"]},
    "sql": {"type": "string"},
    "parameterMappings": {"type": "array"},
    "paramExample": {"type": "object"},
    "locators": {"type": "object"},
    "riskFlags": {"type": "array", "items": {"type": "string"}},
    "templateSql": {"type": "string"},
    "dynamicFeatures": {"type": "array", "items": {"type": "string"}},
    "templateTarget": {"type": "string"},
    "primaryFragmentTarget": {"type": ["string", "null"]},
    "includeBindings": {"type": "array", "items": {"type": "object"}},
    "fingerprint": {"type": "string"},
    "sampleSource": {"type": "string"},
    "scanConfidence": {"type": "string"},
    "scanWarnings": {"type": ["array", "null"], "items": {"type": "object"}},
    "dynamicTrace": {"type": ["object", "null"]},
    "includeTrace": {"type": ["array", "null"], "items": {"type": "string"}},
    "verification": {"type": ["object", "null"]}
  }
}
