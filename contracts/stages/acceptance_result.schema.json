{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AcceptanceResult",
  "type": "object",
  "required": ["sqlKey", "status", "equivalence", "perfComparison", "securityChecks"],
  "additionalProperties": false,
  "$defs": {
    "verificationRecord": {
      "type": "object",
      "required": [
        "run_id",
        "sql_key",
        "statement_key",
        "phase",
        "status",
        "reason_code",
        "reason_message",
        "evidence_refs",
        "inputs",
        "checks",
        "verdict",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "run_id": {"type": "string"},
        "sql_key": {"type": "string"},
        "statement_key": {"type": "string"},
        "phase": {"type": "string"},
        "status": {"type": "string"},
        "reason_code": {"type": "string"},
        "reason_message": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "object"},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "ok", "severity"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "ok": {"type": "boolean"},
              "severity": {"type": "string"},
              "reason_code": {"type": ["string", "null"]},
              "detail": {"type": ["string", "null"]},
              "evidence_ref": {"type": ["string", "null"]}
            }
          }
        },
        "verdict": {"type": "object"},
        "created_at": {"type": "string"}
      }
    }
  },
  "properties": {
    "sqlKey": {"type": "string"},
    "status": {"type": "string"},
    "rewrittenSql": {"type": ["string", "null"]},
    "equivalence": {
      "type": "object",
      "properties": {
        "checked": {"type": ["boolean", "null"]},
        "method": {"type": ["string", "null"]},
        "rowCount": {"type": ["object", "null"]},
        "keySetHash": {"type": ["object", "null"]},
        "rowSampleHash": {"type": ["object", "null"]},
        "evidenceRefs": {"type": ["array", "null"], "items": {"type": "string"}},
        "evidenceRefObjects": {"type": ["array", "null"], "items": {"type": "object"}}
      }
    },
    "perfComparison": {
      "type": "object",
      "properties": {
        "checked": {"type": ["boolean", "null"]},
        "method": {"type": ["string", "null"]},
        "beforeSummary": {"type": ["object", "null"]},
        "afterSummary": {"type": ["object", "null"]},
        "reasonCodes": {"type": ["array", "null"], "items": {"type": "string"}},
        "improved": {"type": ["boolean", "null"]},
        "error": {"type": ["string", "null"]},
        "evidenceRefs": {"type": ["array", "null"], "items": {"type": "string"}},
        "evidenceRefObjects": {"type": ["array", "null"], "items": {"type": "object"}}
      }
    },
    "securityChecks": {"type": "object"},
    "feedback": {"type": ["object", "null"]},
    "semanticRisk": {"type": "string"},
    "selectedCandidateSource": {"type": "string"},
    "selectedCandidateId": {"type": ["string", "null"]},
    "candidateEvaluations": {"type": "array", "items": {"type": "object"}},
    "candidateEval": {"type": ["object", "null"]},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "riskFlags": {"type": "array", "items": {"type": "string"}},
    "selectionRationale": {
      "type": ["object", "null"],
      "required": ["strategy"],
      "properties": {
        "strategy": {"type": "string"},
        "reasonCodes": {"type": ["array", "null"], "items": {"type": "string"}},
        "summary": {"type": ["string", "null"]},
        "runnerUpCandidateId": {"type": ["string", "null"]}
      }
    },
    "decisionLayers": {
      "type": ["object", "null"],
      "required": ["feasibility", "evidence", "acceptance"],
      "properties": {
        "feasibility": {"type": "object"},
        "evidence": {"type": "object"},
        "delivery": {"type": ["object", "null"]},
        "acceptance": {"type": "object"}
      }
    },
    "llmSemanticCheck": {"type": ["object", "null"]},
    "semanticEquivalence": {
      "type": ["object", "null"],
      "required": ["status", "confidence", "evidenceLevel"],
      "properties": {
        "status": {"type": ["string", "null"]},
        "confidence": {"type": ["string", "null"]},
        "confidenceBeforeUpgrade": {"type": ["string", "null"]},
        "confidenceUpgradeApplied": {"type": ["boolean", "null"]},
        "confidenceUpgradeReasons": {"type": ["array", "null"], "items": {"type": "string"}},
        "confidenceUpgradeEvidenceSources": {"type": ["array", "null"], "items": {"type": "string"}},
        "evidenceLevel": {"type": ["string", "null"]},
        "checks": {"type": ["object", "null"]},
        "reasons": {"type": ["array", "null"], "items": {"type": "string"}},
        "hardConflicts": {"type": ["array", "null"], "items": {"type": "string"}},
        "equivalenceOverrideApplied": {"type": ["boolean", "null"]},
        "equivalenceOverrideRule": {"type": ["string", "null"]},
        "coverage": {"type": ["object", "null"]},
        "evidence": {"type": ["object", "null"]}
      }
    },
    "canonicalization": {"type": ["object", "null"]},
    "candidateSelectionTrace": {"type": ["array", "null"], "items": {"type": "object"}},
    "verification": {
      "type": ["object", "null"],
      "required": [
        "run_id",
        "sql_key",
        "statement_key",
        "phase",
        "status",
        "reason_code",
        "reason_message",
        "evidence_refs",
        "inputs",
        "checks",
        "verdict",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "run_id": {"type": "string"},
        "sql_key": {"type": "string"},
        "statement_key": {"type": "string"},
        "phase": {"type": "string"},
        "status": {"type": "string"},
        "reason_code": {"type": "string"},
        "reason_message": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "object"},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "ok", "severity"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "ok": {"type": "boolean"},
              "severity": {"type": "string"},
              "reason_code": {"type": ["string", "null"]},
              "detail": {"type": ["string", "null"]},
              "evidence_ref": {"type": ["string", "null"]}
            }
          }
        },
        "verdict": {"type": "object"},
        "created_at": {"type": "string"}
      }
    }
  }
}
