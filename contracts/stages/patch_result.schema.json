{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchResult",
  "type": "object",
  "required": ["sqlKey", "patchFiles", "diffSummary", "applyMode", "rollback"],
  "additionalProperties": false,
  "properties": {
    "sqlKey": {"type": "string"},
    "statementKey": {"type": ["string", "null"]},
    "patchFiles": {"type": "array", "items": {"type": "string"}},
    "diffSummary": {
      "type": "object",
      "required": ["skipped", "changed"],
      "additionalProperties": false,
      "properties": {
        "skipped": {"type": "boolean"},
        "changed": {"type": "boolean"},
        "lines": {"type": ["integer", "null"]}
      }
    },
    "applyMode": {"type": "string"},
    "rollback": {"type": "string"},
    "selectedCandidateId": {"type": ["string", "null"]},
    "patchFamily": {"type": ["string", "null"]},
    "artifactKind": {"type": ["string", "null"]},
    "deliveryStage": {"type": ["string", "null"]},
    "failureClass": {"type": ["string", "null"]},
    "candidatesEvaluated": {"type": ["integer", "null"]},
    "applicable": {"type": ["boolean", "null"]},
    "applyCheckError": {"type": ["string", "null"]},
    "selectionReason": {
      "type": ["object", "null"],
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"}
      }
    },
    "rejectedCandidates": {"type": ["array", "null"], "items": {"type": "object"}},
    "deliveryOutcome": {
      "type": ["object", "null"],
      "required": ["tier"],
      "properties": {
        "tier": {"type": "string"},
        "reasonCodes": {"type": ["array", "null"], "items": {"type": "string"}},
        "summary": {"type": ["string", "null"]}
      }
    },
    "repairHints": {"type": ["array", "null"], "items": {"type": "object"}},
    "patchability": {"type": ["object", "null"]},
    "selectionEvidence": {
      "type": ["object", "null"],
      "required": ["acceptanceStatus"],
      "properties": {
        "acceptanceStatus": {"type": ["string", "null"]},
        "repairabilityStatus": {"type": ["string", "null"]},
        "semanticGateStatus": {"type": ["string", "null"]},
        "semanticGateConfidence": {"type": ["string", "null"]}
      }
    },
    "fallbackReasonCodes": {"type": ["array", "null"], "items": {"type": "string"}},
    "strategyType": {"type": ["string", "null"]},
    "fallbackApplied": {"type": ["boolean", "null"]},
    "dynamicTemplateStrategy": {"type": ["string", "null"]},
    "dynamicTemplateBlockingReason": {"type": ["string", "null"]},
    "gates": {
      "type": ["object", "null"],
      "required": [
        "semanticEquivalenceStatus",
        "semanticEquivalenceBlocking",
        "semanticConfidence",
        "semanticEvidenceLevel"
      ],
      "properties": {
        "semanticEquivalenceStatus": {"type": ["string", "null"]},
        "semanticEquivalenceBlocking": {"type": ["boolean", "null"]},
        "semanticConfidence": {"type": ["string", "null"]},
        "semanticEvidenceLevel": {"type": ["string", "null"]}
      }
    },
    "replayEvidence": {"type": ["object", "null"]},
    "syntaxEvidence": {"type": ["object", "null"]},
    "verification": {
      "type": ["object", "null"],
      "required": [
        "run_id",
        "sql_key",
        "statement_key",
        "phase",
        "status",
        "reason_code",
        "reason_message",
        "evidence_refs",
        "inputs",
        "checks",
        "verdict",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "run_id": {"type": "string"},
        "sql_key": {"type": "string"},
        "statement_key": {"type": "string"},
        "phase": {"type": "string"},
        "status": {"type": "string"},
        "reason_code": {"type": "string"},
        "reason_message": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "object"},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "ok", "severity"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "ok": {"type": "boolean"},
              "severity": {"type": "string"},
              "reason_code": {"type": ["string", "null"]},
              "detail": {"type": ["string", "null"]},
              "evidence_ref": {"type": ["string", "null"]}
            }
          }
        },
        "verdict": {"type": "object"},
        "created_at": {"type": "string"}
      }
    }
  }
}
